#pragma region Filtrage
//--------------------------------------------------------------
void applyFiltrage()
{
  // Lecture brute
  ImuSample rawSample = {accX, accY, accZ, gyroX, gyroY, gyroZ};
  accX_raw_fl = static_cast<float>(rawSample.accX);
  accY_raw_fl = static_cast<float>(rawSample.accY);
  accZ_raw_fl = static_cast<float>(rawSample.accZ);
  gyroX_raw_fl = static_cast<float>(rawSample.gyroX);
  gyroY_raw_fl = static_cast<float>(rawSample.gyroY);
  gyroZ_raw_fl = static_cast<float>(rawSample.gyroZ);

  imuFilter.setType(filtreActuel);
  imuFilter.setIntervalMs(interval_ms);
  FilteredImuSample filteredSample = imuFilter.update(rawSample);

  accX_filtered = filteredSample.accX;
  accY_filtered = filteredSample.accY;
  accZ_filtered = filteredSample.accZ;
  gyroX_filtered = filteredSample.gyroX;
  gyroY_filtered = filteredSample.gyroY;
  gyroZ_filtered = filteredSample.gyroZ;

  // Affichage : brut, puis filtré
  // Pour Tracé uniquement Mettre en commentaire en version finale
  int16_t accXF2int, accYF2int, accZF2int, gyroXF2int, gyroYF2int, gyroZF2int;
  accXF2int = static_cast<int16_t>(accX_filtered);
  accYF2int = static_cast<int16_t>(accY_filtered);
  accZF2int = static_cast<int16_t>(accZ_filtered);
  gyroXF2int = static_cast<int16_t>(gyroX_filtered);
  gyroYF2int = static_cast<int16_t>(gyroY_filtered);
  gyroZF2int = static_cast<int16_t>(gyroZ_filtered);

  // 6 data brutes
  // Serial.printf("%d,%d,%d,%d,%d,%d\n", accX, accY, accZ, gyroX, gyroY, gyroYF2int);
  // 6 data brutes  + 6 data Filtrées
  //  Serial.printf("%d,%d,%d,%d,%d,%d\n", accX, accY, accZ, gyroX, gyroY, gyroZ);
  // Serial.printf("%d,%d,%d,%d,%d,%d,", accX, accY, accZ, gyroX, gyroY, gyroZ);
  // Serial.printf("%d,%d,%d,%d,%d,%d\n", accXF2int, accYF2int, accZF2int, gyroXF2int, gyroYF2int, gyroZF2int);
  // delay(10);
}
