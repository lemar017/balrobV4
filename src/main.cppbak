  Serial.write((uint8_t)(accZ >> 8));
  Serial.write((uint8_t)(accZ & 0xFF));
  Serial.write((uint8_t)(gyroX >> 8));
  Serial.write((uint8_t)(gyroX & 0xFF));
  Serial.write((uint8_t)(gyroY >> 8));
  Serial.write((uint8_t)(gyroY & 0xFF));
  Serial.write((uint8_t)(gyroZ >> 8));
  Serial.write((uint8_t)(gyroZ & 0xFF));
}
