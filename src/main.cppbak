//--------------------------------------------------------------
void offsetAccGyro() // valeurs du 19-10-2024 OK
{
  mpu.setXAccelOffset(1019);
  mpu.setYAccelOffset(-518);
  mpu.setZAccelOffset(8812);
  mpu.setXGyroOffset(-425);
  mpu.setYGyroOffset(105);
  mpu.setZGyroOffset(-544);

  Serial.println("-------Offset Acc et Gyro -------");
  Serial.println("XAccelOffset = 1019");
  Serial.println("YAccelOffset = -518");
  Serial.println("ZAccelOffset = 8812");
  Serial.println("XGyroOffset = -425");
  Serial.println("YGyroOffset = -105");
  Serial.println("ZGyroOffset = -544");
  Serial.println("----------------------------------");
}
//--------------------------------------------------------------

//--------------------------------------------------------------
float calculPID(float dt, float Y)
{
  FilteredImuSample filteredSample = {
      accX_filtered,
      accY_filtered,
      accZ_filtered,
      gyroX_filtered,
      gyroY_filtered,
      gyroZ_filtered};
  JoystickState joystick = {static_cast<float>(joyX), Y};
  PidSettings settings = {TA, KP, KI, KD};

  motorPID = balanceController.compute(dt, filteredSample, joystick, settings);
  const BalanceTelemetry &telemetry = balanceController.telemetry();
  accAngle = telemetry.accAngle;
  gyroRate = telemetry.gyroRate;
  gyroAngle = telemetry.gyroAngle;
  currentAngle = telemetry.currentAngle;
  targetAngle = telemetry.targetAngle;
  error = telemetry.error;
  errorSum = telemetry.errorSum;
  P = telemetry.p;
  I = telemetry.i;
  D = telemetry.d;
  prevAngle = currentAngle;

  return motorPID;
}
// ------------------------gestion moteurs-----------------------
void controlMotors(float PID, float X, float Y)
{
  // === 1. PID → vitesse ===
  const float Kspeed = 25.0; // Réduit de 20.0 à 5.0 pour limiter la vitesse

  float baseSpeed = PID * Kspeed;

  // === 2. Rotation (joyX) ===
  // float joy = X;

  // Zone morte
  if (abs(X) < 5)
    X = 0;

  float joyNorm = X / 100.0;

  const float Krot = 500.0; // Réduit de 800.0 à 500.0 pour limiter la rotation

  float rotation = joyNorm * Krot;

  // === 3. Sécurité (option très utile) ===
  float tilt = abs(currentAngle - targetAngle);
  if (tilt > 6.0)
  {
    rotation *= 0.5;
  }

  // === 4. Différentiel ===
  const float speedG = baseSpeed - rotation;
  const float speedD = baseSpeed + rotation;

  // === 5. Envoi à ta classe MotorDriver ===
  /*
   Serial.print("speedG: ");
   Serial.print(speedG);
   Serial.print(", speedD: ");
   Serial.println(speedD);
 */
  motors.setSpeed(speedG, speedD);
}

//--------------------------------------------------------------

//**************************************************************
//                         SETUP
//**************************************************************
#pragma region setup
void setup()
{

  //----------------------Com WIFI et Serveur WEB--------------------

  Serial.begin(115200);
  pinMode(LED_BUILTIN, OUTPUT); // Or use the correct pin number for your LED
  initSDCard();                 // Initialise la carte SD et affiche le type de carte
  initWiFi();                   // Initialise le WIFI et affiche l'adresse IP du serveur ESP32

  server.serveStatic("/", SD, "/balrob/");
  receivePIDenTR(); // reception de TA,KP,KD,KI en TR(Temps réel) suite à modif Sliders
  initServerWeb();  // On demande au serveur la page index.HTML
  JSON2Client();    // lecture SD
  JSON2Server();    // Ecriture SD
  sendXYJoystick();
  initVarPIDfromSD();
  server.begin();
  infoProg(); // Affiche ce que fait le programme mais une fois le serveur démarré affiche dans log HTML
  //----------------------Timer-LED-PID--------------------------------
  pinMode(PIN_LED_OK, OUTPUT);

  //-----------------------I2C----------------------------------
  //  join I2C bus (I2Cdev library doesn't do this automatically)
#if I2CDEV_IMPLEMENTATION == I2CDEV_ARDUINO_WIRE
  Wire.begin();
#elif I2CDEV_IMPLEMENTATION == I2CDEV_BUILTIN_FASTWIRE
  Fastwire::setup(400, true);
#endif

  //---------------------MPU6050-------------------------------------

  Serial.println("Initializing I2C devices MPU6050...");
  mpu.initialize();
  Serial.println(mpu.testConnection() ? "MPU6050 connection successful" : "MPU6050 connection failed");

  //----------------------?------------------------------
  error = 0;
  errorSum = 0;
  tempsDebut = millis();
  //---------------------Offset Acc et Gyro-------------------------
  offsetAccGyro(); // Valeur des offsets à partir d'un programme indépendant
  mpu.CalibrateAccel(6);
  mpu.CalibrateGyro(6);
  //----------------------Init Parametres moteur---------------------
  // Initialisation du moteur de la bibliothèque

  // iniMoteurs(); // Initialise les moteurs et configure les pins de direction
  motors.begin(STEP_G, DIR_G, STEP_D, DIR_D, MAX_MOTOR_SPEED_HZ); // Initialise les moteurs avec les pins et une accélération de 1000 Hz/s
}
#pragma endregion
//**************************************************************
//                        LOOP
//**************************************************************
void loop()
{
  loopWiFi(); // Gestion asynchrone de la connexion WIFI

  accX = mpu.getAccelerationX();
  accY = mpu.getAccelerationY();
  accZ = mpu.getAccelerationZ();
  gyroX = mpu.getRotationX();
  gyroY = mpu.getRotationY();
  gyroZ = mpu.getRotationZ();

  applyFiltrage(); // Applique le filtrage sur les valeurs lues

  // ✨ NEW: Mise à jour centralisée du timing (à appeler UNE FOIS au début)
  timing.update();

  // 1. BOUCLE DE CONTRÔLE (Priorité haute)

  // === PID (Temps réel) ===
  if (timing.shouldExecutePID())
  {
    // ✨ NEW: Obtenir le delta time depuis TimingController
    float vrai_dt = timing.getDeltaTimeSeconds();

    // Calcul du PID et mise à jour des moteurs
    myPID = calculPID(vrai_dt, joyY);
    controlMotors(myPID, joyX, joyY);
  }

  // === LED de statut (500 ms) ===
  // Sortie du bloc PID pour être totalement indépendante
  if (timing.shouldToggleLED())
  {
    etatLED = !etatLED;
    digitalWrite(PIN_LED_OK, etatLED);
  }

#pragma region cacheAffiche
  // 2. BOUCLE D'AFFICHAGE (Plus lente pour ne pas saturer le WiFi)
  if (timing.shouldDisplayData())
  {
#if AFFICHE_DATA_ACC_GYRO == true
    printData();
#endif
#if AFFICHE_DATA_BINAIRE == true
    printDataBinaire();
#endif
#if AFFICHE_DATA_ONTIMER == true
    printDataOnTimer();
#endif
#if AFFICHE_DATA_FILTREE == true
    printDataFiltree();
#endif
#if AFFICHE_EFFICACITE_FILTREE == true
    efficaciteFiltre();
#endif
#if AFFICHE_CONSIGNES_PID == true
    printConsignesPID();
#endif
#if AFFICHE_VALEURS_PID == true
    printValeursPID();
#endif
  }
#pragma endregion
}
